<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/black" />

        <ImageView
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:src="@drawable/logo"
            android:contentDescription="@string/cd_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="@string/check_email_title"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/check_email_desc"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <!-- OTP Input Boxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="8">

            <EditText
                android:id="@+id/otpDigit1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit3"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit4"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit5"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit6"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit7"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/otpDigit8"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="16sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerifyCode"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:alpha="0.5"
            android:text="@string/verify_code_btn"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/resend_email_prompt"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvResendEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/resend_email"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>