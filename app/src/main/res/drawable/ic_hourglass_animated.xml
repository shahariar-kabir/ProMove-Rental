<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="120dp"
            android:height="120dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <group
                android:name="hourglass_group"
                android:pivotX="12"
                android:pivotY="12">
                <!-- Frame -->
                <path
                    android:fillColor="#8D2424"
                    android:pathData="M6,2V8H6V8L10,12L6,16V16H6V22H18V16H18V16L14,12L18,8V8H18V2H6M16,16.5V20H8V16.5L12,12.5L16,16.5Z" />
                <!-- Upper Sand -->
                <path
                    android:name="upper_sand"
                    android:fillColor="#FBC02D"
                    android:pathData="M12,11.5L8,7.5V4H16V7.5L12,11.5Z" />
                <!-- Lower Sand (Initially small/empty) -->
                <path
                    android:name="lower_sand"
                    android:fillColor="#FBC02D"
                    android:pathData="M12,12.5L12,12.5L12,12.5L12,12.5L12,12.5Z" />
            </group>
        </vector>
    </aapt:attr>

    <target android:name="hourglass_group">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="2000"
                android:propertyName="rotation"
                android:valueFrom="0"
                android:valueTo="180"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"
                android:repeatCount="infinite"
                android:repeatMode="restart" />
        </aapt:attr>
    </target>

    <target android:name="upper_sand">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="2000"
                android:propertyName="pathData"
                android:valueFrom="M12,11.5L8,7.5V4H16V7.5L12,11.5Z"
                android:valueTo="M12,11.5L12,11.5V11.5H12V11.5L12,11.5Z"
                android:valueType="pathType"
                android:repeatCount="infinite"
                android:repeatMode="restart" />
        </aapt:attr>
    </target>

    <target android:name="lower_sand">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="2000"
                android:propertyName="pathData"
                android:valueFrom="M12,12.5L12,12.5V12.5H12V12.5L12,12.5Z"
                android:valueTo="M12,12.5L8,16.5V20H16V16.5L12,12.5Z"
                android:valueType="pathType"
                android:repeatCount="infinite"
                android:repeatMode="restart" />
        </aapt:attr>
    </target>
</animated-vector>
